+# ── 单轮输出上限 max_tokens：显式 > CONTEXTFORGE_MAX_TOKENS > 默认 8192（P2）──
+
+def test_max_tokens_default(monkeypatch):
+    """不传不设环境 → 用默认 8192（P2：从写死的 2048 调高，编码 agent 写大文件够用）。"""
+    from contextforge.agent import MAX_TOKENS_DEFAULT
+    monkeypatch.delenv("CONTEXTFORGE_MAX_TOKENS", raising=False)
+    assert MAX_TOKENS_DEFAULT == 8192          # 固化「调高到 8192」这个决策，防回退到 2048
+    assert Agent().max_tokens == 8192
+
+
+def test_max_tokens_reads_env(monkeypatch):
+    """CONTEXTFORGE_MAX_TOKENS 环境兜底：可按需调更高/更低。"""
+    monkeypatch.setenv("CONTEXTFORGE_MAX_TOKENS", "16000")
+    assert Agent().max_tokens == 16000
+
+
+def test_explicit_max_tokens_overrides_env(monkeypatch):
+    """显式传参优先于环境变量。"""
+    monkeypatch.setenv("CONTEXTFORGE_MAX_TOKENS", "16000")
+    assert Agent(max_tokens=4096).max_tokens == 4096
+
+
+def test_max_tokens_invalid_env_falls_back(monkeypatch):
+    """环境变量非法（非正整数）→ 兜底回默认 8192，不报错。"""
+    for bad in ["abc", "-5", "0", ""]:
+        monkeypatch.setenv("CONTEXTFORGE_MAX_TOKENS", bad)
+        assert Agent().max_tokens == 8192
+
+
+def test_max_tokens_used_in_think_and_summarize_calls(monkeypatch):
+    """回归 P2：Think 主调用与压缩摘要都必须用 self.max_tokens，不能再写死 2048。"""
+    import unittest.mock as mock
+    monkeypatch.setenv("CONTEXTFORGE_TRACE", "off")
+    monkeypatch.setenv("CONTEXTFORGE_LOG", "off")
+    monkeypatch.delenv("CONTEXTFORGE_MAX_TOKENS", raising=False)
+
+    a = Agent()
+    fake_resp = mock.Mock()
+    fake_resp.content = [mock.Mock(type="text", text="ok")]
+    a.client = mock.Mock()
+    a.client.messages.create.return_value = fake_resp
+
+    # 压缩摘要走 _summarize → 应带 max_tokens=8192（默认），绝不是 2048。
+    a._summarize("请总结这段历史")
+    _, kwargs = a.client.messages.create.call_args
+    assert kwargs["max_tokens"] == a.max_tokens == 8192
+
+
