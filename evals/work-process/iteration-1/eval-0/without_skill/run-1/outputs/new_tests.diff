+# ── P1：工具并发安全标记（只读并发、写/跑命令串行）────────────────
+
+def test_read_file_is_concurrency_safe():
+    """read_file 只读无副作用 → 并发安全，可与别的工具并行。"""
+    assert is_concurrency_safe("read_file") is True
+
+
+def test_write_and_run_command_not_concurrency_safe():
+    """write_file / run_command 有副作用 → 不并发安全（同轮并行写同一文件会竞态）。"""
+    assert is_concurrency_safe("write_file") is False
+    assert is_concurrency_safe("run_command") is False
+
+
+def test_unknown_tool_defaults_not_concurrency_safe():
+    """未登记的工具默认不安全——保守串行，绝不因遗漏标记引入竞态。"""
+    assert is_concurrency_safe("no_such_tool_xyz") is False
+
+
+def test_concurrency_safe_flag_not_in_schema():
+    """并发安全标记是调度用的带外信息，不该出现在给模型的 input_schema 里。"""
+    rf = next(s for s in TOOL_SCHEMAS if s["name"] == "read_file")
+    assert "concurrency_safe" not in rf["input_schema"]["properties"]
+    assert "concurrency_safe" not in rf  # 也不在 schema 顶层
