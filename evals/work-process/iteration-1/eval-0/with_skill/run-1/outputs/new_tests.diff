+# ── P1：并发工具执行分读写——只读并发、有副作用串行（消除同轮写同一文件竞态）──
+
+def _run_one_round_measuring_concurrency(monkeypatch, tool_name):
+    """让假模型在一轮里发 8 个同名工具调用，测量执行时它们的最大并发数。
+
+    通过 monkeypatch agent 模块里的 execute_tool 成一个「进出计数 + sleep」的探针：
+    若这些调用被并行执行，探针会观测到 max_concurrent > 1；若串行，则恒为 1。
+    这正是 P1 的判据——有副作用的工具（write_file/run_command）必须串行，否则同轮写
+    同一文件竞态、最终内容由线程调度决定。read_file 只读则应仍并行（保留加速）。
+    """
+    import threading
+    import time
+    import unittest.mock as mock
+    import contextforge.agent as agentmod
+
+    monkeypatch.setenv("CONTEXTFORGE_TRACE", "off")
+    monkeypatch.setenv("CONTEXTFORGE_LOG", "off")
+
+    state = {"active": 0, "max": 0}
+    lock = threading.Lock()
+
+    def probe(name, tool_input, read_files=None):
+        with lock:
+            state["active"] += 1
+            state["max"] = max(state["max"], state["active"])
+        time.sleep(0.02)  # 给并行一个「撞在一起」的时间窗；串行则永不重叠
+        with lock:
+            state["active"] -= 1
+        return f"[probe ok] {name}"
+
+    monkeypatch.setattr(agentmod, "execute_tool", probe)
+
+    a = Agent(max_iterations=2)
+    n = {"i": 0}
+
+    def fake_create(**kw):
+        n["i"] += 1
+        if n["i"] == 1:
+            blocks = [_FakeTUBlock("tool_use", id=f"x{i}", name=tool_name,
+                                   input={"path": "same.txt", "content": f"v{i}"}
+                                   if tool_name != "run_command" else {"command": f"echo {i}"})
+                      for i in range(8)]
+            return _FakeResp(blocks, "tool_use")
+        return _FakeResp([_FakeTUBlock("text", text="done")], "end_turn")
+
+    with mock.patch.object(a.client.messages, "create", side_effect=fake_create):
+        a.run("一轮里发 8 个工具调用")
+    return state["max"]
+
+
+def test_side_effecting_tools_run_serially_in_one_round(monkeypatch):
+    """P1 核心：同轮 8 个 write_file 必须串行（max_concurrent == 1），否则写同一文件竞态。
+
+    基线（无脑并行 max_workers=8）上，这 8 个 write 会同时在飞、max 观测为 8 → 本断言 fail，
+    正是「同轮并行写同一文件竞态」的确定性证据。修复后按并发安全性分批、有副作用串行 → max==1。
+    """
+    assert _run_one_round_measuring_concurrency(monkeypatch, "write_file") == 1
+
+
+def test_run_command_also_serial_in_one_round(monkeypatch):
+    """run_command 同样有副作用 → 同轮多个也须串行（顺序确定，不并发交错）。"""
+    assert _run_one_round_measuring_concurrency(monkeypatch, "run_command") == 1
+
+
+def test_read_only_tools_still_parallel_in_one_round(monkeypatch):
+    """回归护栏：read_file 只读无副作用 → 同轮多个仍并行（max>1），别把加速一起改没了。"""
+    assert _run_one_round_measuring_concurrency(monkeypatch, "read_file") > 1
+
